{
  "version": 2,
  "name": "physician-locator",
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors * "
        }
      ]
    }
  ],
  "routes": [
    { "src": "/env.js", "dest": "/env.js" },
    { "src": "/(.*)",   "dest": "/index.html" }
  ]
}